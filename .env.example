# Supabase - lấy từ https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - CHỈ dùng ở server-side, KHÔNG bao giờ expose ra client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LapLap

# AI providers cho module phân tích mô tả sản phẩm (/api/ai/parse-product)
# Chỉ cần điền key cho provider bạn dùng. Gemini có free tier rộng.
GEMINI_API_KEY=
OPENAI_API_KEY=
